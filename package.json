{
  "name": "achmage-markdown-renderer",
  "version": "6.0.0-beta.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "node scripts/run-with-local-env.mjs ./node_modules/astro/astro.js dev",
    "start": "node scripts/run-with-local-env.mjs ./node_modules/astro/astro.js dev",
    "build": "node scripts/run-with-local-env.mjs ./node_modules/astro/astro.js build",
    "preview": "node scripts/run-with-local-env.mjs ./node_modules/astro/astro.js preview",
    "package:v4": "node scripts/package-v4.mjs",
    "package:release": "node scripts/package-v4.mjs",
    "check": "node scripts/run-with-local-env.mjs ./node_modules/astro/astro.js check",
    "test": "node scripts/run-with-local-env.mjs ./node_modules/vitest/vitest.mjs run --pool forks",
    "test:watch": "node scripts/run-with-local-env.mjs ./node_modules/vitest/vitest.mjs --pool forks",
    "test:e2e": "node scripts/run-with-local-env.mjs ./node_modules/playwright/cli.js test"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "astro": "^5.2.3",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
