{
  "name": "achmage-reader-universal-v5",
  "private": true,
  "version": "6.0.0-beta.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:windows": "tauri build --bundles msi --ci --no-sign",
    "package:macos": "tauri build --target universal-apple-darwin --bundles app,dmg --ci --no-sign",
    "package:beta:desktop": "npm run package:windows",
    "stage:release-assets": "node scripts/stage-release-assets.mjs",
    "verify:release-assets": "node scripts/verify-release-assets.mjs",
    "package:release-manifest": "node scripts/write-release-manifest.mjs release-assets",
    "release:beta": "npm run package:windows && npm run stage:release-assets -- --platform windows && npm run verify:release-assets -- --platform windows && npm run package:release-manifest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "github-slugger": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
