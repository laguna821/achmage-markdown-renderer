---
import StageDeck from '../components/stage/StageDeck.astro';
import SiteHeader from '../components/shell/SiteHeader.astro';
import BaseLayout from './BaseLayout.astro';

import type {NormalizedDoc} from '../lib/content';

interface Props {
  doc: NormalizedDoc;
}

const {doc} = Astro.props;
---

<BaseLayout
  pageTitle={`${doc.meta.title} | Stage`}
  theme={doc.meta.theme}
  themeLocked={doc.meta.theme !== 'auto'}
  bodyClass="mode-stage"
  outputMode="stage"
  docSlug={doc.slug}
  pretextEnabled={true}
>
  <SiteHeader doc={doc} variant="stage" />
  <StageDeck doc={doc} />
</BaseLayout>
