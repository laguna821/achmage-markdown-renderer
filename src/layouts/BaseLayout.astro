---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/prose.css';
import '../styles/blocks.css';
import '../styles/stage.css';

interface Props {
  pageTitle: string;
  theme?: 'light' | 'dark' | 'aurora' | 'cyber_sanctuary' | 'auto';
  themeLocked?: boolean;
  bodyClass?: string;
  outputMode?: 'reader' | 'stage' | 'newsletter';
  docSlug?: string;
  pretextEnabled?: boolean;
}

const {
  pageTitle,
  theme = 'light',
  themeLocked = false,
  bodyClass = '',
  outputMode,
  docSlug,
  pretextEnabled = false,
} = Astro.props;
const initialTheme = theme === 'auto' ? 'light' : theme;
const isThemeLocked = themeLocked && theme !== 'auto';
---

<!doctype html>
<html lang="ko" data-theme={initialTheme} data-theme-default={initialTheme} data-theme-locked={String(isThemeLocked)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Newsreader:opsz,wght@6..72,400..800&family=Space+Grotesk:wght@300;400;500;700&display=swap"
    />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css"
    />
    <script is:inline>
      (() => {
        const storageKey = 'achmage-theme';
        const root = document.documentElement;
        const supportedThemes = ['light', 'dark', 'aurora', 'cyber_sanctuary'];
        const isSupportedTheme = (value) => typeof value === 'string' && supportedThemes.includes(value);
        const resolveColorScheme = (themeName) =>
          themeName === 'dark' || themeName === 'cyber_sanctuary' ? 'dark' : 'light';
        const defaultTheme = isSupportedTheme(root.dataset.themeDefault)
          ? root.dataset.themeDefault
          : isSupportedTheme(root.dataset.theme)
            ? root.dataset.theme
            : 'light';
        const lockedTheme = root.dataset.themeLocked === 'true' ? defaultTheme : null;
        try {
          const storedTheme = window.localStorage.getItem(storageKey);
          const nextTheme = lockedTheme ?? (isSupportedTheme(storedTheme) ? storedTheme : defaultTheme);
          root.dataset.theme = nextTheme;
          root.style.colorScheme = resolveColorScheme(nextTheme);
        } catch {
          root.dataset.theme = defaultTheme;
          root.style.colorScheme = resolveColorScheme(defaultTheme);
        }
      })();
    </script>
    <title>{pageTitle}</title>
  </head>
  <body
    class={bodyClass}
    data-output-mode={outputMode}
    data-doc-slug={docSlug}
    data-pretext-enabled={String(pretextEnabled)}
  >
    <slot />
    <script is:inline>
      (() => {
        const storageKey = 'achmage-theme';
        const root = document.documentElement;
        const themeOrder = ['light', 'dark', 'aurora', 'cyber_sanctuary'];
        const themeMeta = {
          light: {
            label: 'LIGHT MODE',
            state: '1 / 4',
            announcement: 'Current theme: light mode. Switch to dark mode.',
          },
          dark: {
            label: 'DARK MODE',
            state: '2 / 4',
            announcement: 'Current theme: dark mode. Switch to aurora glow mode.',
          },
          aurora: {
            label: 'AURORA GLOW',
            state: '3 / 4',
            announcement: 'Current theme: aurora glow mode. Switch to cyber sanctuary mode.',
          },
          cyber_sanctuary: {
            label: 'CYBER SANCTUARY',
            state: '4 / 4',
            announcement: 'Current theme: cyber sanctuary mode. Switch to light mode.',
          },
        };
        const isSupportedTheme = (value) => typeof value === 'string' && themeOrder.includes(value);
        const resolveColorScheme = (themeName) =>
          themeName === 'dark' || themeName === 'cyber_sanctuary' ? 'dark' : 'light';
        const defaultTheme = isSupportedTheme(root.dataset.themeDefault) ? root.dataset.themeDefault : 'light';
        const themeLocked = root.dataset.themeLocked === 'true';
        const getNextTheme = (currentTheme) => {
          const currentIndex = themeOrder.indexOf(currentTheme);
          return themeOrder[(currentIndex + 1 + themeOrder.length) % themeOrder.length];
        };

        const applyTheme = (nextTheme) => {
          const themeName = themeLocked
            ? defaultTheme
            : isSupportedTheme(nextTheme)
              ? nextTheme
              : defaultTheme;
          const {label: themeLabel, state: themeState, announcement} = themeMeta[themeName];

          root.dataset.theme = themeName;
          root.style.colorScheme = resolveColorScheme(themeName);

          document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
            button.toggleAttribute('disabled', themeLocked);
            button.setAttribute('aria-disabled', themeLocked ? 'true' : 'false');
            button.setAttribute('data-theme-locked', themeLocked ? 'true' : 'false');
            button.setAttribute(
              'aria-label',
              themeLocked ? `Document theme locked to ${themeLabel.toLowerCase()}.` : announcement,
            );

            const labelNode = button.querySelector('[data-theme-label]');
            const stateNode = button.querySelector('[data-theme-state]');
            if (labelNode) labelNode.textContent = themeLabel;
            if (stateNode) stateNode.textContent = themeState;
          });
        };

        document.addEventListener('click', (event) => {
          const button = event.target instanceof Element ? event.target.closest('[data-theme-toggle]') : null;
          if (!button || themeLocked) return;

          const nextTheme = getNextTheme(isSupportedTheme(root.dataset.theme) ? root.dataset.theme : defaultTheme);
          applyTheme(nextTheme);

          try {
            window.localStorage.setItem(storageKey, nextTheme);
          } catch {
            // Ignore storage failures and keep the in-memory theme.
          }
        });

        applyTheme(isSupportedTheme(root.dataset.theme) ? root.dataset.theme : defaultTheme);
      })();
    </script>
  </body>
</html>
