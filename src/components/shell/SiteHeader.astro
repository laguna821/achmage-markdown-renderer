---
import {getDocumentModeLinks} from '../../lib/stage';

import type {NormalizedDoc} from '../../lib/content';

interface Props {
  doc?: NormalizedDoc;
  variant?: 'reader' | 'stage' | 'newsletter' | 'home';
}

const {doc, variant = 'reader'} = Astro.props;
const activeMode = variant === 'reader' || variant === 'stage' || variant === 'newsletter' ? variant : undefined;
const modeLinks = doc ? getDocumentModeLinks(doc, activeMode) : [];
---

<header class:list={['site-header', `site-header--${variant}`]}>
  <div class="site-header__brand">
    <a href="/">Achmage Markdown Renderer</a>
  </div>
  <div class="site-header__context">
    {doc ? (
      <>
        <span class="site-header__mode">{variant.toUpperCase()}</span>
        <span class="site-header__title">{doc.meta.title}</span>
        {modeLinks.length > 0 && (
          <nav class="site-header__modes" aria-label="Document modes">
            {modeLinks.map((link) => (
              <a class:list={['site-header__mode-link', link.active && 'is-active']} href={link.href} aria-current={link.active ? 'page' : undefined}>
                {link.label}
              </a>
            ))}
          </nav>
        )}
      </>
    ) : (
      <span class="site-header__mode">STATIC-FIRST DOC ENGINE</span>
    )}
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Current theme: light mode. Switch to dark mode.">
      <span class="theme-toggle__orb" aria-hidden="true"></span>
      <span class="theme-toggle__label" data-theme-label>LIGHT MODE</span>
      <span class="theme-toggle__state" data-theme-state>1 / 4</span>
    </button>
  </div>
</header>
