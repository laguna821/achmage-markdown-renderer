---
import TocList from './TocList.astro';

import type {NormalizedDoc} from '../../lib/content';

interface Props {
  doc: NormalizedDoc;
}

const {doc} = Astro.props;
---

<aside class="doc-rail" aria-label="Document rail">
  {doc.meta.rail.showToc && doc.headings.length > 0 && (
    <section class="doc-rail__panel">
      <h2>{doc.meta.tocTitle}</h2>
      <TocList items={doc.headings} />
    </section>
  )}

  {doc.meta.rail.showMetadata && (
    <section class="doc-rail__panel">
      <h2>METADATA</h2>
      <dl class="doc-rail__meta">
        <div>
          <dt>Type</dt>
          <dd>{doc.meta.docType}</dd>
        </div>
        {doc.meta.author && (
          <div>
            <dt>Author</dt>
            <dd>{doc.meta.author}</dd>
          </div>
        )}
        {doc.meta.date && (
          <div>
            <dt>Date</dt>
            <dd>{doc.meta.date}</dd>
          </div>
        )}
        <div>
          <dt>Outputs</dt>
          <dd>{doc.meta.outputs.join(', ')}</dd>
        </div>
      </dl>
    </section>
  )}

  {doc.meta.rail.showTags && doc.meta.tags.length > 0 && (
    <section class="doc-rail__panel">
      <h2>TAGS</h2>
      <div class="tag-strip">
        {doc.meta.tags.map((tag) => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    </section>
  )}
</aside>
