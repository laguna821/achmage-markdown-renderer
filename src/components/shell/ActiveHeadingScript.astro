<script is:inline>
  (() => {
    const tocLinks = Array.from(document.querySelectorAll('[data-toc-item]'));
    const headings = Array.from(
      document.querySelectorAll(
        '.doc-article h1[id], .doc-article h2[id], .doc-article h3[id], .doc-article h4[id], .doc-article h5[id], .doc-article h6[id]',
      ),
    );

    if (tocLinks.length === 0 || headings.length === 0) return;

    const activate = (id) => {
      tocLinks.forEach((link) => {
        link.classList.toggle('is-active', link.getAttribute('data-toc-item') === id);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

        if (!visible) return;
        activate(visible.target.id);
      },
      {
        rootMargin: '-20% 0px -60% 0px',
        threshold: [0, 1],
      },
    );

    headings.forEach((heading) => observer.observe(heading));
  })();
</script>
