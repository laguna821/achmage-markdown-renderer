---
interface Item {
  id?: string;
  title: string;
  body: string;
  tag?: string;
}

interface Props {
  items: Item[];
}

const {items} = Astro.props;
---

<section class="evidence-grid">
  {items.map((item) => (
    <article class="evidence-card">
      {item.tag && <div class="evidence-card__tag">{item.tag}</div>}
      <h3 id={item.id} class="evidence-card__title">
        {item.title}
      </h3>
      <div class="evidence-card__body" set:html={item.body} />
    </article>
  ))}
</section>
