---
interface Item {
  id?: string;
  title: string;
  body: string;
}

interface Props {
  items: Item[];
}

const {items} = Astro.props;
---

<section class="question-reset">
  {items.map((item, index) => (
    <article class="question-reset__card">
      <div class="question-reset__index">{index === 0 ? 'BEFORE' : 'REFRAME'}</div>
      <h3 id={item.id} class="question-reset__title">
        {item.title}
      </h3>
      <div class="question-reset__body" set:html={item.body} />
    </article>
  ))}
</section>
