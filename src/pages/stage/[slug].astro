---
import {getDocumentsForStage} from '../../lib/stage';
import StageLayout from '../../layouts/StageLayout.astro';

export const getStaticPaths = () =>
  getDocumentsForStage().map((doc) => ({
    params: {slug: doc.slug},
    props: {doc},
  }));

const {doc} = Astro.props;
---

<StageLayout doc={doc} />
